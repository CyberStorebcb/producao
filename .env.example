# Este arquivo é só DOCUMENTAÇÃO — o Vite e as APIs NÃO leem .env.example.
# Copie para ".env.local" na raiz (mesma pasta que package.json) e preencha.
# Reinicie "npm run dev" após salvar.

# Neon / Postgres (obrigatório para histórico Kaizen, produção no DB, etc.)
# POSTGRES_URL=postgresql://USUARIO:SENHA@HOST/neondb?sslmode=require
# ou:
# DATABASE_URL=postgresql://...

POSTGRES_URL=

# Sincronização Kaizen (SIGA)
KAIZEN_SIGA_USERNAME=
KAIZEN_SIGA_PASSWORD=

# Clima no lobby (opcional)
# WEATHERAPI_KEY=
